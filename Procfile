web: python manage.py migrate --noinput && (if [ -f data_backup.json ]; then echo "=== RESTORING DATA ===" && python manage.py flush --noinput && python manage.py loaddata data_backup.json && echo "=== RESTORE DONE ==="; fi) && python manage.py bootstrap_admin && python manage.py collectstatic --noinput --clear && gunicorn config.wsgi:application -c config/gunicorn.conf.py
