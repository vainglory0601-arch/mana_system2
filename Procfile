web: python manage.py migrate --noinput && echo "CWD=$(pwd) | FILE=$(ls /workspace/data_backup.json 2>&1)" && (if [ -f /workspace/data_backup.json ]; then echo "=== RESTORING DATA ===" && python manage.py flush --noinput && python manage.py loaddata /workspace/data_backup.json && echo "=== RESTORE DONE ==="; else echo "=== BACKUP FILE NOT FOUND ==="; fi) && python manage.py bootstrap_admin && python manage.py collectstatic --noinput --clear && gunicorn config.wsgi:application -c config/gunicorn.conf.py
